<Window x:Class="ProgPart2.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgPart2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">


    <Grid>


        <!-- Header -->
        <Border Background="#FF1E2A44"
                Height="80"
                VerticalAlignment="Top">


            <Grid>


                <TextBlock Text="🐶"
                           FontSize="40"
                           HorizontalAlignment="Left"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>



                <TextBlock Text="CYBER SECURITY AWARENESS BOT"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>



                <!-- Activity Log Button -->
                <Button Content="📜 Activity Log"
                        Width="130"
                        Height="35"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0"
                        Background="#FF00C853"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="ActivityLogButton_Click"/>


            </Grid>


        </Border>





        <!-- Chat Area -->

        <ScrollViewer Margin="20,90,20,130"
                      VerticalScrollBarVisibility="Auto"
                      Name="ChatScrollViewer"
                      Background="#FF0F1629">


            <StackPanel Name="ChatPanel"
                        Margin="10"/>


        </ScrollViewer>







        <!-- Input Area -->

        <Border Background="#FF1E2A44"
                Height="100"
                VerticalAlignment="Bottom"
                Margin="20">


            <Grid>


                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>





                <TextBox Name="InputTextBox"

                         Height="50"

                         Margin="20,0,10,0"

                         FontSize="16"

                         Background="#FF2A3A5A"

                         Foreground="White"

                         VerticalContentAlignment="Center"

                         KeyDown="InputTextBox_KeyDown"

                         Padding="10"/>






                <Button Content="Send"

                        Grid.Column="1"

                        Width="100"

                        Height="50"

                        Margin="0,0,20,0"

                        FontSize="16"

                        FontWeight="Bold"

                        Background="#FF00C853"

                        Foreground="White"

                        Click="SendButton_Click"/>



            </Grid>


        </Border>







        <!-- Status -->


        <TextBlock Name="StatusText"

                   Text="Ready - Ask me anything about cybersecurity!"

                   HorizontalAlignment="Center"

                   VerticalAlignment="Bottom"

                   Margin="0,0,0,20"

                   Foreground="#FF00C853"

                   FontSize="14"/>



    </Grid>


</Window>
